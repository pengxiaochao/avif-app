{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "avif-image",
  "version": "0.1.0",
  "identifier": "com.avifimage.app",
  "build": {
    "frontendDist": "../ui/dist",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "label": "main",
        "title": "avif-image 偏好设置",
        "width": 800,
        "height": 560,
        "minWidth": 640,
        "minHeight": 440,
        "visible": false,
        "decorations": true,
        "resizable": true,
        "center": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null
    }
  }
}
